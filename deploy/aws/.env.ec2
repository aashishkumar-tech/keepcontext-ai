# KeepContext AI on AWS EC2 (free-tier-conscious)
# Copy to .env.ec2 and fill values.

# Required API keys
OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=gsk-your-groq-key

# App settings
APP_NAME=keepcontext-ai
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Chroma (kept internal to compose network)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# OpenAI embedding model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Groq model settings
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024

# Neo4j (recommended: use Neo4j Aura Free so EC2 does not host Neo4j)
# If you do not have Aura yet, set placeholder values. Graph features will be disabled
# gracefully when connection fails.
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password

# Agent settings
AGENT_MAX_STEPS=2
AGENT_TIMEOUT=60
